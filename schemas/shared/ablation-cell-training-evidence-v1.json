{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/ablation-cell-training-evidence-v1.json",
  "title": "Stage 8 trained ablation cell evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "matrix_id", "matrix_hash", "cell_id", "config_hash",
    "seed", "runtime_id", "training_run_id", "training_result_hash",
    "checkpoint_refs", "metrics_ref", "metrics_hash", "parent_evidence_hash",
    "scope", "formal_eligible", "formal_authorization_hash", "artifact_hash"
  ],
  "properties": {
    "schema_version": {"const": "ablation-cell-training-evidence-v1"},
    "matrix_id": {"$ref": "#/$defs/id"},
    "matrix_hash": {"$ref": "#/$defs/hash"},
    "cell_id": {"$ref": "#/$defs/id"},
    "config_hash": {"$ref": "#/$defs/hash"},
    "seed": {"type": "integer", "minimum": 0},
    "runtime_id": {"$ref": "#/$defs/id"},
    "training_run_id": {"$ref": "#/$defs/id"},
    "training_result_hash": {"$ref": "#/$defs/hash"},
    "checkpoint_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/ref"}
    },
    "metrics_ref": {"$ref": "#/$defs/ref"},
    "metrics_hash": {"$ref": "#/$defs/hash"},
    "parent_evidence_hash": {
      "oneOf": [{"type": "null"}, {"$ref": "#/$defs/hash"}]
    },
    "scope": {"enum": ["local_fixture", "formal"]},
    "formal_eligible": {"type": "boolean"},
    "formal_authorization_hash": {
      "oneOf": [{"type": "null"}, {"$ref": "#/$defs/hash"}]
    },
    "artifact_hash": {"$ref": "#/$defs/hash"}
  },
  "allOf": [
    {
      "if": {"properties": {"scope": {"const": "formal"}}},
      "then": {
        "properties": {
          "formal_eligible": {"const": true},
          "formal_authorization_hash": {"$ref": "#/$defs/hash"}
        }
      },
      "else": {
        "properties": {
          "formal_eligible": {"const": false},
          "formal_authorization_hash": {"type": "null"}
        }
      }
    }
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,191}$"},
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"
    }
  }
}
