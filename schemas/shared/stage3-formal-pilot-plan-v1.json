{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/stage3-formal-pilot-plan-v1.json",
  "title": "Stage 3 preregistered formal quadrature pilot plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "scope", "candidate_rules", "required_unit_ids", "thresholds", "execution_evidence_hash", "formal_eligible", "artifact_hash"],
  "properties": {
    "schema_version": {"const": "stage3-formal-pilot-plan-v1"},
    "plan_id": {"$ref": "#/$defs/id"},
    "scope": {"const": "formal"},
    "candidate_rules": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "required_unit_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "thresholds": {"$ref": "#/$defs/thresholds"},
    "execution_evidence_hash": {"$ref": "#/$defs/hash"},
    "formal_eligible": {"const": true},
    "artifact_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,159}$"},
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_normalized_l1_error", "max_completeness_absolute_residual", "min_spearman", "min_topk_overlap", "max_unique_nodes"],
      "properties": {
        "max_normalized_l1_error": {"type": "number", "minimum": 0},
        "max_completeness_absolute_residual": {"type": "number", "minimum": 0},
        "min_spearman": {"type": "number", "minimum": -1, "maximum": 1},
        "min_topk_overlap": {"type": "number", "minimum": 0, "maximum": 1},
        "max_unique_nodes": {"type": "integer", "minimum": 1}
      }
    }
  }
}
