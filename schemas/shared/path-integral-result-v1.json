{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/path-integral-result-v1.json",
  "title": "Stage 3 path integral result manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "path_identity_hash", "rule", "contribution_bundle_ref",
    "contribution_bundle_manifest_hash", "views", "endpoint_loss_pre", "endpoint_loss_post",
    "loss_drop", "completeness_absolute_residual", "completeness_relative_residual",
    "completeness_l1_scaled_residual", "node_losses", "unique_gradient_evaluations", "artifact_hash"
  ],
  "properties": {
    "schema_version": {"const": "path-integral-result-v1"},
    "path_identity_hash": {"$ref": "#/$defs/hash"},
    "rule": {"$ref": "#/$defs/rule"},
    "contribution_bundle_ref": {"$ref": "#/$defs/ref"},
    "contribution_bundle_manifest_hash": {"$ref": "#/$defs/hash"},
    "views": {"const": ["signed", "positive", "negative_mass", "absolute"]},
    "endpoint_loss_pre": {"$ref": "#/$defs/nullableNumber"},
    "endpoint_loss_post": {"$ref": "#/$defs/nullableNumber"},
    "loss_drop": {"$ref": "#/$defs/nullableNumber"},
    "completeness_absolute_residual": {"$ref": "#/$defs/nonnegativeNullableNumber"},
    "completeness_relative_residual": {"$ref": "#/$defs/nonnegativeNullableNumber"},
    "completeness_l1_scaled_residual": {"$ref": "#/$defs/nonnegativeNullableNumber"},
    "node_losses": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nullableNumber"}},
    "unique_gradient_evaluations": {"type": "integer", "minimum": 1},
    "artifact_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "ref": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"},
    "nullableNumber": {"oneOf": [{"type": "null"}, {"type": "number"}]},
    "nonnegativeNullableNumber": {"oneOf": [{"type": "null"}, {"type": "number", "minimum": 0}]},
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "kind", "nodes", "weights", "subintervals", "exact_polynomial_degree", "theoretical_order"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1},
        "nodes": {"type": "array", "minItems": 1, "items": {"type": "number", "minimum": 0, "maximum": 1}},
        "weights": {"type": "array", "minItems": 1, "items": {"type": "number", "minimum": 0}},
        "subintervals": {"oneOf": [{"type": "null"}, {"type": "integer", "minimum": 1}]},
        "exact_polynomial_degree": {"type": "integer", "minimum": 0},
        "theoretical_order": {"type": "integer", "minimum": 1}
      }
    }
  }
}
