{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/pruning-study-result-v1.json",
  "title": "Stage 7 complete pruning study result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "study_id", "study_hash", "result_ids", "result_hashes", "scope", "formal_eligible", "artifact_hash"],
  "properties": {
    "schema_version": {"const": "pruning-study-result-v1"},
    "study_id": {"type": "string", "minLength": 1},
    "study_hash": {"$ref": "#/$defs/hash"},
    "result_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "result_hashes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/hash"}},
    "scope": {"enum": ["local_fixture", "formal"]},
    "formal_eligible": {"type": "boolean"},
    "artifact_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {"hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}
