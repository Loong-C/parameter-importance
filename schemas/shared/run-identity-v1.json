{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/run-identity-v1.json",
  "title": "Experiment/run/attempt/session identity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "experiment_id", "run_id", "attempt_id", "session_id",
    "run_created_at", "attempt_started_at", "parent_experiment_id", "input_run_id",
    "input_checkpoint_id", "artifact_hash"
  ],
  "properties": {
    "schema_version": {"const": "run-identity-v1"},
    "experiment_id": {"type": "string", "pattern": "^exp-s[0-9]-[a-z0-9]+(?:-[a-z0-9]+)*-[0-9a-f]{16}$"},
    "run_id": {"type": "string", "pattern": "^run-[0-9a-f]{16}-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$"},
    "attempt_id": {"type": "integer", "minimum": 1},
    "session_id": {"type": "string", "pattern": "^run-.+\\.a[0-9]{4,}\\.s001$"},
    "run_created_at": {"type": "string", "format": "date-time"},
    "attempt_started_at": {"type": "string", "format": "date-time"},
    "parent_experiment_id": {"$ref": "#/$defs/optionalRef"},
    "input_run_id": {"$ref": "#/$defs/optionalRef"},
    "input_checkpoint_id": {"$ref": "#/$defs/optionalRef"},
    "artifact_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "optionalRef": {"oneOf": [{"type": "null"}, {"type": "string", "minLength": 1, "maxLength": 512}]}
  }
}
