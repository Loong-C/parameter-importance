{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/bound-frozen-source-table-v1.json",
  "title": "Scope and lineage bound frozen source table",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "table", "role", "scope", "formal_eligible", "parent_artifact_hashes", "derivation_id", "artifact_hash"],
  "properties": {
    "schema_version": {"const": "bound-frozen-source-table-v1"},
    "table": {"$ref": "#/$defs/table"},
    "role": {"type": "string", "minLength": 1},
    "scope": {"enum": ["local_fixture", "formal"]},
    "formal_eligible": {"type": "boolean"},
    "parent_artifact_hashes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/hash"}},
    "derivation_id": {"type": "string", "minLength": 1},
    "artifact_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "schema_version", "rows", "content_hash", "frozen"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "schema_version": {"type": "string", "minLength": 1},
        "rows": {"type": "array", "minItems": 1, "items": {"type": "object", "minProperties": 1}},
        "content_hash": {"$ref": "#/$defs/hash"},
        "frozen": {"const": true}
      }
    }
  }
}
