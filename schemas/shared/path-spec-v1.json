{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/path-spec-v1.json",
  "title": "Stage 3 path specification manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "path_id", "probe_id", "loss_id", "accumulation_dtype",
    "registry_hash", "parameter_names", "parameter_pre_bundle_ref",
    "parameter_pre_bundle_manifest_hash", "parameter_post_bundle_ref",
    "parameter_post_bundle_manifest_hash", "path_identity_hash", "artifact_hash"
  ],
  "properties": {
    "schema_version": {"const": "path-spec-v1"},
    "path_id": {"type": "string", "minLength": 1},
    "probe_id": {"type": "string", "minLength": 1},
    "loss_id": {"type": "string", "minLength": 1},
    "accumulation_dtype": {"enum": ["float32", "float64"]},
    "registry_hash": {"$ref": "#/$defs/hash"},
    "parameter_names": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "parameter_pre_bundle_ref": {"$ref": "#/$defs/ref"},
    "parameter_pre_bundle_manifest_hash": {"$ref": "#/$defs/hash"},
    "parameter_post_bundle_ref": {"$ref": "#/$defs/ref"},
    "parameter_post_bundle_manifest_hash": {"$ref": "#/$defs/hash"},
    "path_identity_hash": {"$ref": "#/$defs/hash"},
    "artifact_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "ref": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"}
  }
}
