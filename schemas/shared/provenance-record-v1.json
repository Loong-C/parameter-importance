{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/provenance-record-v1.json",
  "title": "Allowlisted run provenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "identity", "config_hash", "resolved_config_ref", "seed_plan_hash",
    "git_commit", "git_branch", "worktree_clean", "scope", "formal_eligible", "dirty_base_commit",
    "dirty_patch_ref", "dirty_patch_hash", "environment_id", "hardware_snapshot_ref",
    "device_mapping", "model_manifest_id", "tokenizer_manifest_id", "data_manifest_id",
    "started_at", "ended_at", "status", "resume_checkpoint_id", "artifact_refs", "artifact_hash"
  ],
  "properties": {
    "schema_version": {"const": "provenance-record-v1"},
    "identity": {"$ref": "run-identity-v1.json"},
    "config_hash": {"$ref": "#/$defs/hash"},
    "resolved_config_ref": {"$ref": "#/$defs/ref"},
    "seed_plan_hash": {"$ref": "#/$defs/hash"},
    "git_commit": {"type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"},
    "git_branch": {"type": "string", "minLength": 1, "maxLength": 512},
    "worktree_clean": {"type": "boolean"},
    "scope": {"enum": ["local_fixture", "formal"]},
    "formal_eligible": {"type": "boolean"},
    "dirty_base_commit": {"$ref": "#/$defs/optionalRef"},
    "dirty_patch_ref": {"$ref": "#/$defs/optionalRef"},
    "dirty_patch_hash": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/hash"}]},
    "environment_id": {"$ref": "#/$defs/ref"},
    "hardware_snapshot_ref": {"$ref": "#/$defs/ref"},
    "device_mapping": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/ref"}},
    "model_manifest_id": {"$ref": "#/$defs/ref"},
    "tokenizer_manifest_id": {"$ref": "#/$defs/optionalRef"},
    "data_manifest_id": {"$ref": "#/$defs/ref"},
    "started_at": {"type": "string", "format": "date-time"},
    "ended_at": {"oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
    "status": {"enum": ["STARTED", "COMPLETED", "FAILED", "BLOCKED"]},
    "resume_checkpoint_id": {"$ref": "#/$defs/optionalRef"},
    "artifact_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/ref"}},
    "artifact_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "ref": {"type": "string", "minLength": 1, "maxLength": 4096},
    "optionalRef": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/ref"}]}
  }
}
