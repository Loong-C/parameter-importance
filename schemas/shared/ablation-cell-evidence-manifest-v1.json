{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/ablation-cell-evidence-manifest-v1.json",
  "title": "Hash-bound Stage 8 ablation cell evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "matrix_hash", "checkpoint_artifact_hash", "scope", "formal_eligible", "cells", "artifact_hash"],
  "properties": {
    "schema_version": {"const": "ablation-cell-evidence-manifest-v1"},
    "matrix_hash": {"$ref": "#/$defs/hash"},
    "checkpoint_artifact_hash": {"$ref": "#/$defs/hash"},
    "scope": {"enum": ["local_fixture", "formal"]},
    "formal_eligible": {"type": "boolean"},
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cell_id", "config_hash", "metrics", "metric_directions", "evidence_hash", "result_ref"],
        "properties": {
          "cell_id": {"type": "string", "minLength": 1},
          "config_hash": {"$ref": "#/$defs/hash"},
          "metrics": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "number"}},
          "metric_directions": {"type": "object", "minProperties": 1, "additionalProperties": {"enum": ["higher_is_better", "lower_is_better"]}},
          "evidence_hash": {"$ref": "#/$defs/hash"},
          "result_ref": {"$ref": "#/$defs/ref"}
        }
      }
    },
    "artifact_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "ref": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"}
  }
}
