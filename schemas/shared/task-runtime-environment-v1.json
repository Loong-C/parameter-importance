{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/task-runtime-environment-v1.json",
  "title": "Verified task runtime environment snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "capabilities", "frozen_contract_stages",
    "passed_gate_ids", "estimator_decision_ref", "evidence_refs",
    "environment_hash"
  ],
  "properties": {
    "schema_version": {"const": "task-runtime-environment-v1"},
    "capabilities": {
      "type": "array", "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
    },
    "frozen_contract_stages": {
      "type": "array", "uniqueItems": true,
      "items": {"type": "integer", "minimum": 0, "maximum": 9}
    },
    "passed_gate_ids": {
      "type": "array", "uniqueItems": true,
      "items": {"type": "string", "pattern": "^stage[0-9]\\.G[0-9]+(?:[.-][A-Za-z0-9]+)*$"}
    },
    "estimator_decision_ref": {
      "oneOf": [{"type": "null"}, {"$ref": "#/$defs/logicalRef"}]
    },
    "evidence_refs": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9_]*$"},
      "additionalProperties": {"$ref": "#/$defs/logicalRef"}
    },
    "environment_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "logicalRef": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"}
  }
}
