{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/stage3-quadrature-recommendation-v1.json",
  "title": "Stage 3 quadrature recommendation and formal qualification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "recommendation_id", "status", "default_rule", "fallback_rule", "passing_rules", "required_unit_ids", "thresholds", "thresholds_hash", "execution_evidence_hash", "scope", "formal_eligible", "qualification_gate_hash", "reasons", "artifact_hash"],
  "properties": {
    "schema_version": {"const": "stage3-quadrature-recommendation-v1"},
    "recommendation_id": {"$ref": "#/$defs/id"},
    "status": {"enum": ["FIXTURE_RECOMMENDATION", "FORMAL_CANDIDATE", "QUALIFIED", "BLOCKED"]},
    "default_rule": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/id"}]},
    "fallback_rule": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/id"}]},
    "passing_rules": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "required_unit_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "thresholds": {"$ref": "#/$defs/thresholds"},
    "thresholds_hash": {"$ref": "#/$defs/hash"},
    "execution_evidence_hash": {"$ref": "#/$defs/hash"},
    "scope": {"enum": ["local_fixture", "formal"]},
    "formal_eligible": {"type": "boolean"},
    "qualification_gate_hash": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/hash"}]},
    "reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "artifact_hash": {"$ref": "#/$defs/hash"}
  },
  "allOf": [
    {
      "if": {"properties": {"formal_eligible": {"const": true}}, "required": ["formal_eligible"]},
      "then": {"properties": {"scope": {"const": "formal"}, "status": {"const": "QUALIFIED"}, "qualification_gate_hash": {"$ref": "#/$defs/hash"}}},
      "else": {"properties": {"qualification_gate_hash": {"type": "null"}}}
    }
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,159}$"},
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_normalized_l1_error", "max_completeness_absolute_residual", "min_spearman", "min_topk_overlap", "max_unique_nodes"],
      "properties": {
        "max_normalized_l1_error": {"type": "number", "minimum": 0},
        "max_completeness_absolute_residual": {"type": "number", "minimum": 0},
        "min_spearman": {"type": "number", "minimum": -1, "maximum": 1},
        "min_topk_overlap": {"type": "number", "minimum": 0, "maximum": 1},
        "max_unique_nodes": {"type": "integer", "minimum": 1}
      }
    }
  }
}
