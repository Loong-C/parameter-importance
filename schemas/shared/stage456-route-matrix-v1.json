{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/stage456-route-matrix-v1.json",
  "title": "Stage 6 hash-bound route matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "matrix_id",
    "base_initialization_id",
    "base_initialization_tensor_hash",
    "coordinate_registry_hash",
    "route_lineage_hashes",
    "route_refs",
    "route_execution_sources",
    "evaluation_contract_hashes",
    "paired_by",
    "scope",
    "formal_eligible",
    "artifact_hash"
  ],
  "properties": {
    "schema_version": {"const": "stage456-route-matrix-v1"},
    "matrix_id": {"type": "string", "minLength": 1},
    "base_initialization_id": {"type": "string", "minLength": 1},
    "base_initialization_tensor_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "coordinate_registry_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "route_lineage_hashes": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    },
    "route_refs": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)[.][.](?:/|$)).+$"}
    },
    "route_execution_sources": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "object"}
    },
    "evaluation_contract_hashes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    },
    "paired_by": {
      "type": "array",
      "const": ["task_id", "global_step", "split", "panel_sample_ids_hash", "base_initialization_id"]
    },
    "scope": {"enum": ["local_fixture", "formal"]},
    "formal_eligible": {"type": "boolean"},
    "artifact_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "allOf": [
    {
      "if": {"properties": {"scope": {"const": "formal"}}, "required": ["scope"]},
      "then": {"properties": {"formal_eligible": {"const": true}}},
      "else": {"properties": {"formal_eligible": {"const": false}}}
    }
  ]
}
