{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parameter-importance.invalid/schemas/shared/stage3-probe-plan-v1.json",
  "title": "Stage 3 probe plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "panel_id",
    "endpoint_digest",
    "entries",
    "minimum_formal_probes",
    "execution_evidence_hash",
    "scope",
    "formal_eligible",
    "artifact_hash"
  ],
  "properties": {
    "schema_version": {"const": "stage3-probe-plan-v1"},
    "panel_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,159}$"},
    "endpoint_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "probe_id", "sample_ids", "content_hash", "loss_contract_hash", "effective_weight_unit", "metadata"],
        "properties": {
          "role": {"enum": ["pilot", "formal", "replay"]},
          "probe_id": {"type": "string", "minLength": 1},
          "sample_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": ["string", "integer"]}},
          "content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "loss_contract_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "effective_weight_unit": {"type": "string", "minLength": 1},
          "metadata": {"type": "object"}
        }
      }
    },
    "minimum_formal_probes": {"type": "integer", "minimum": 1},
    "execution_evidence_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "scope": {"enum": ["local_fixture", "formal"]},
    "formal_eligible": {"type": "boolean"},
    "artifact_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
